# ═════════════════════════════════════════════════════════════════════════
# COINTELLIGENCE ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════
#
# This file contains all environment variables needed to run Cointelligence.
# Copy this file to .env and fill in the values below.
#
# IMPORTANT: .env is NOT committed to git. It contains secrets.
#            Only .env.example is committed.
#
# ═════════════════════════════════════════════════════════════════════════

# APPLICATION
# ═════════════════════════════════════════════════════════════════════════

NODE_ENV=production
# Set to "production" for deployed VMs or "development" for local dev

NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# The public URL where the site is accessible
# Examples: https://cointelligence.example.com, http://localhost:3000
# This is used for OAuth redirects and OG metadata


# ADMIN CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════

ADMIN_EMAILS=richard.ramdial@gmail.com
# Comma-separated list of email addresses allowed to access the admin panel
# These emails can sign in via Google OAuth (case-insensitive)
# Examples:
#   ADMIN_EMAILS=richard@example.com
#   ADMIN_EMAILS=richard@example.com,admin@example.com
#   ADMIN_EMAILS=admin1@example.com,admin2@example.com

ADMIN_PASSWORD=your-secure-admin-password
# Password for local (email+password) authentication
# Used when creating admin user via seed script: npm run payload seed
# Also used as fallback password if seeding multiple admins
#
# IMPORTANT: This is only used during initial setup
# After first login, admins change their passwords in the CMS
#
# Generate a secure password:
#   $ openssl rand -base64 24
#   or manually choose a strong password (12+ characters, mixed case, numbers, symbols)


# PAYLOAD CMS
# ═════════════════════════════════════════════════════════════════════════

PAYLOAD_SECRET=your-payload-secret-key-here
# Secret key used to sign Payload JWTs
#
# GENERATE A STRONG SECRET:
#   $ node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# This should be a random 64+ character hex string
# Keep this SECRET — never share or expose in logs


# DATABASE (PostgreSQL 16)
# ═════════════════════════════════════════════════════════════════════════

POSTGRES_USER=cointelligence
# PostgreSQL user created by docker-compose.yml
# Used by the 'db' container and the 'app' container to authenticate

POSTGRES_PASSWORD=your-secure-password-here
# PostgreSQL password for the POSTGRES_USER
#
# GENERATE A STRONG PASSWORD:
#   $ openssl rand -base64 24
#
# This should be a random string with uppercase, lowercase, numbers, symbols
# Keep this SECRET — only on the VM in .env file

POSTGRES_DB=cointelligence
# PostgreSQL database name created by docker-compose.yml

DATABASE_URI=postgresql://cointelligence:your-secure-password-here@db:5432/cointelligence
# Full PostgreSQL connection string for Payload
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# IMPORTANT FOR DOCKER:
#   The HOST is 'db' (the service name in docker-compose.yml)
#   The PORT is 5432 (internal, not exposed outside containers)
#   Replace USER and PASSWORD with POSTGRES_USER and POSTGRES_PASSWORD above
#
# Example:
#   DATABASE_URI=postgresql://cointelligence:mySecurePassword123@db:5432/cointelligence


# MEDIA UPLOAD
# ═════════════════════════════════════════════════════════════════════════

PAYLOAD_PUBLIC_UPLOAD_DIR=/app/media
# Directory inside the app container where uploaded images are stored
# This maps to the 'media_data' named volume in docker-compose.yml
# DO NOT CHANGE THIS — it must match the docker-compose volume mount


# TRAEFIK / LET'S ENCRYPT
# ═════════════════════════════════════════════════════════════════════════

ACME_EMAIL=your-email@example.com
# Email address used for Let's Encrypt certificate notifications
# Let's Encrypt will send renewal reminders to this address
# Use a real email you monitor


# GOOGLE OAUTH (Optional for Phase 2+)
# ═════════════════════════════════════════════════════════════════════════
#
# These are only needed if implementing Google OAuth login.
# Phase 1 uses Payload's native auth instead.
# Uncomment and fill in when ready for Phase 2+
#
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# NEXTAUTH_SECRET=your-nextauth-secret-key-here
# NEXTAUTH_URL=https://yourdomain.com
#
# To set up Google OAuth:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project "Cointelligence"
# 3. Enable Google+ API
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Add authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (local)
#    - https://yourdomain.com/api/auth/callback/google (production)
# 6. Copy Client ID and Client Secret here
# 7. Generate NEXTAUTH_SECRET:
#    $ node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"


# ═════════════════════════════════════════════════════════════════════════
# QUICK START FOR AZURE VM
# ═════════════════════════════════════════════════════════════════════════
#
# 1. SSH into the VM:
#    $ ssh azureuser@<VM_IP>
#
# 2. Navigate to the project:
#    $ cd ~/cointelligence
#
# 3. Create .env file:
#    $ cat > .env << 'EOF'
#    NODE_ENV=production
#    NEXT_PUBLIC_SITE_URL=https://yourdomain.com
#    PAYLOAD_SECRET=$(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
#    POSTGRES_USER=cointelligence
#    POSTGRES_PASSWORD=$(openssl rand -base64 24)
#    POSTGRES_DB=cointelligence
#    DATABASE_URI=postgresql://cointelligence:<PASSWORD>@db:5432/cointelligence
#    PAYLOAD_PUBLIC_UPLOAD_DIR=/app/media
#    ACME_EMAIL=your-email@example.com
#    EOF
#
# 4. Start the services:
#    $ docker compose pull
#    $ docker compose up -d
#
# 5. Seed the admin user:
#    $ docker compose exec app npx ts-node scripts/seed.ts
#
# 6. Verify deployment:
#    $ docker compose ps
#    $ docker compose logs app
#
# ═════════════════════════════════════════════════════════════════════════
